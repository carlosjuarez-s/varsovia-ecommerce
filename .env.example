# ============================================================
#  Varsovia Backend — Variables de Entorno
#  Copiá este archivo como .env y completá los valores
# ============================================================

# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5500
BACKEND_URL=http://localhost:3001

# ─── MercadoPago ─────────────────────────────────────────────
# Obtené las credenciales en: https://mercadopago.com.ar/developers
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ─── Uber Direct ─────────────────────────────────────────────
# Solicitá acceso en: https://developer.uber.com/docs/deliveries
UBER_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UBER_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UBER_CUSTOMER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Figma ───────────────────────────────────────────────────
# Token: figma.com → Settings → Security → Personal access tokens
FIGMA_TOKEN=figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIGMA_FILE_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Sheets ───────────────────────────────────────────
# 1. Creá un proyecto en console.cloud.google.com
# 2. Habilitá Google Sheets API
# 3. Creá una Service Account → descargá el JSON
# 4. Compartí el spreadsheet con el email de la service account
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_CLIENT_EMAIL=lumiere@lumiere-app.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxx\n-----END PRIVATE KEY-----\n"
# O bien, pegá todo el JSON de la service account:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Tienda ──────────────────────────────────────────────────
STORE_ADDRESS=Tu dirección, San Miguel de Tucumán, Tucumán, Argentina
STORE_PHONE=+5493816000000
